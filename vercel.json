{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/bot-api/:path*",
      "destination": "http://45.136.58.180:3001/:path*"
    },
    {
      "source": "/health",
      "destination": "http://45.136.58.180:3001/health"
    },
    {
      "source": "/qr",
      "destination": "http://45.136.58.180:3001/qr"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
